# Copy to .env at the repo root and fill in values. Never commit .env.

# Primary — Google AI Studio / Gemini API (Gemma 4 + Gemini Flash)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback only — OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: pin OpenRouter model when using --model with an OpenRouter slug
OPENROUTER_MODEL=openrouter/free

# Optional cascade override (provider:model_id,...)
# MODEL_ROUTING_ORDER=google:gemma-4-26b-a4b-it,google:gemini-3.1-flash-lite,openrouter:openrouter/free

# Per-request API timeout in seconds (default 90)
REQUEST_TIMEOUT_S=90

# Disk cache for vision responses (default on; set 0 for fresh run)
CACHE_ENABLED=1
CACHE_DIR=code/.cache

# Downscale images before API upload (saves image tokens; default 1024 max edge)
RESIZE_MAX_PX=1024
